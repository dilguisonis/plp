        ],
        "page_idx": 6
    },
    {
        "type": "text",
        "text": "Reglas básicas ",
        "text_level": 1,
        "bbox": [
            15,
            101,
            130,
            133
        ],
        "page_idx": 6
    },
    {
        "type": "equation",
        "img_path": "images/edb17c5997a1f731eaf7361929adb4d93f92e62ba7cb08aac1026fff0721502a.jpg",
        "text": "$$\n\\begin{array} { r l r } & { \\frac { \\Gamma \\vdash \\tau } { \\Gamma \\vdash \\tau \\setminus \\sigma } } & { \\frac { \\Gamma \\vdash \\tau } { \\tau \\vdash \\tau } \\overset { \\mathbf { x } } { \\simeq } } \\\\ & { \\frac { \\Gamma \\vdash \\tau \\land \\tau } { \\Gamma \\vdash \\tau \\land \\sigma } \\land _ { i } } & { \\frac { \\Gamma \\vdash \\tau \\land \\sigma } { \\Gamma \\vdash \\tau } \\land _ { e _ { 1 } } \\frac { \\Gamma \\vdash \\tau } { \\Gamma } } \\\\ & { \\frac { \\Gamma , \\tau \\vdash \\sigma } { \\Gamma \\vdash \\tau \\Rightarrow \\sigma } \\Rightarrow _ { i } } & { \\frac { \\Gamma \\vdash \\tau \\Rightarrow \\sigma } { \\Gamma \\vdash \\sigma } \\mathrm { ~ T \\vdash \\tau ~ } } \\\\ & { \\frac { \\textnormal { \\texttt { r } } \\lor _ { i } } { \\sigma } \\quad \\frac { \\Gamma \\vdash \\sigma } { \\Gamma \\vdash \\tau \\lor \\sigma } \\lor _ { i _ { 2 } } } & { \\frac { \\Gamma \\vdash \\tau \\lor \\sigma } { \\Gamma \\vdash \\rho } \\mathrm { ~ T \\vdash \\rho ~ } } \\\\ & { \\frac { \\Gamma , \\tau \\vdash \\bot } { \\Gamma \\vdash \\tau } \\neg _ { i } } & { \\frac { \\Gamma \\vdash \\tau \\land \\tau } { \\Gamma \\vdash \\tau } } \\end{array}\n$$",
        "text_format": "latex",
        "bbox": [
            227,
            235,
            737,
            678
        ],
        "page_idx": 6
    },
    {
        "type": "equation",
        "img_path": "images/1d5294e9171a914548e9aa3f3af7fc231d0420355bf6a4a7b110cf1ef4abc6bc.jpg",
        "text": "$$\n\\frac { \\Gamma \\vdash \\lnot \\lnot \\tau } { \\Gamma \\vdash \\tau } \\lnot \\lnot \\lnot \\lnot e\n$$",
        "text_format": "latex",
        "bbox": [
            649,
