        ],
        "page_idx": 2
    },
    {
        "type": "equation",
        "img_path": "images/f4b5faf0cd4bbcff73814ee69ef9af318f707b261bba36d4a9d535909dff000f.jpg",
        "text": "$$\n\\tau : : = P \\mid \\bot \\mid \\neg \\tau \\mid \\tau \\land \\tau \\mid \\tau \\lor \\tau \\mid \\tau \\Rightarrow \\tau\n$$",
        "text_format": "latex",
        "bbox": [
            315,
            247,
            682,
