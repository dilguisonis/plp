    {
        "type": "text",
        "text": "Reglas derivadas ",
        "bbox": [
            15,
            101,
            147,
            133
        ],
        "page_idx": 7
    },
    {
        "type": "equation",
        "img_path": "images/963dc7dfd35e08a89e631e1ca7a466581afb7d2b04b2ea11a52ca9a5718a13b5.jpg",
        "text": "$$\n\\frac { \\Gamma \\vdash \\tau } { \\Gamma \\vdash \\lnot \\tau } \\lnot \\lnot _ { i } \\frac { \\Gamma \\vdash \\tau \\Rightarrow \\sigma \\vdash \\Gamma \\vdash \\lnot \\sigma } { \\Gamma \\vdash \\lnot \\tau } \\mathsf { M } \\mathsf { T }\n$$",
        "text_format": "latex",
        "bbox": [
            289,
