    },
    {
        "type": "image",
        "img_path": "images/1a4e4f13dd47fc8af60f2c8cda1b4fd4565efa9fa1138d0f221acb3b2e2f6049.jpg",
        "image_caption": [],
        "image_footnote": [],
        "bbox": [
            70,
            129,
            97,
            227
        ],
        "page_idx": 4
    },
    {
        "type": "text",
        "text": "Definidos por un conjunto de reglas Las reglas son de la forma: ",
        "bbox": [
            101,
            137,
            452,
            235
        ],
        "page_idx": 4
    },
    {
        "type": "text",
        "text": "Premisa1 Premisa2 . . . Premisan Nombre de Conclusión la regla ",
        "bbox": [
            304,
            262,
            739,
            360
        ],
        "page_idx": 4
    },
    {
        "type": "text",
        "text": "Un caso particular: $n = 0$ ",
        "bbox": [
            101,
            403,
            344,
            447
        ],
        "page_idx": 4
    },
    {
        "type": "text",
        "text": "Nombre de Conclusión la regla ",
        "bbox": [
            426,
            443,
            615,
            517
        ],
        "page_idx": 4
    },
    {
        "type": "text",
        "text": "Por ejemplo,1 ",
        "bbox": [
            103,
            549,
            229,
            592
        ],
        "page_idx": 4
    },
    {
        "type": "image",
        "img_path": "images/c8373457c206caed85f5ffcb54dc3245c3b5e1116b662d6b462e319182bf64df.jpg",
        "image_caption": [],
