        "bbox": [
            77,
            283,
            187,
            330
        ],
        "page_idx": 6
    },
    {
        "type": "text",
        "text": "Objeto que representa un rectôÇangulo de $5 \\times 2$ : ",
        "bbox": [
            80,
            341,
            662,
            386
        ],
        "page_idx": 6
    },
