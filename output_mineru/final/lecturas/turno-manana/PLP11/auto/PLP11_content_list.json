        "table_body": "<table><tr><td rowspan=1 colspan=1>Interfaz:</td><td rowspan=1 colspan=1>area</td></tr><tr><td rowspan=1 colspan=1>Atributos:</td><td rowspan=1 colspan=1>ancho....      (objeto que representa al 5)alto..           (objeto que representa al 2)</td></tr><tr><td rowspan=1 colspan=1>Metodos:</td><td rowspan=1 colspan=1>area^ ancho * alto</td></tr></table>",
        "bbox": [
